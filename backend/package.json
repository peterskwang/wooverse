{
  "name": "wooverse-backend",
  "version": "1.0.0",
  "description": "Wooverse Platform Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "echo 'backend is JS-only, no build needed' && mkdir -p dist && cp -r src dist/src 2>/dev/null || true",
    "start": "node dist/index.js",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "test": "find src -name '*.js' -print0 | xargs -0 node --check && echo 'syntax check OK'",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/websocket": "^10.0.1",
    "@prisma/client": "^5.14.0",
    "ali-oss": "^6.23.0",
    "axios": "^1.7.2",
    "bull": "^4.12.2",
    "dayjs": "^1.11.11",
    "dotenv": "^16.4.5",
    "fastify": "^4.27.0",
    "ioredis": "^5.4.1",
    "pino": "^9.2.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/ali-oss": "^6.23.3",
    "@types/bull": "^4.10.0",
    "@types/node": "^20.14.2",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^9.5.0",
    "prisma": "^5.14.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
